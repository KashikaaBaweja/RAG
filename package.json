{
  "name": "rag-monorepo",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "dev:stack": "docker compose up -d && turbo dev --filter=web --filter=worker",
    "lint": "turbo lint",
    "test": "turbo test",
    "test:e2e": "pnpm --filter web test:e2e",
    "typecheck": "turbo typecheck"
  },
  "devDependencies": {
    "openai": "^4.77.3",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "packageManager": "pnpm@9.15.0"
}
