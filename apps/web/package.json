{
  "name": "web",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "prisma generate --schema=./prisma/schema.prisma && next dev",
    "build": "prisma generate --schema=./prisma/schema.prisma && next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "vitest run --config ../../vitest.config.ts",
    "test:watch": "vitest --config ../../vitest.config.ts",
    "test:e2e": "playwright test --config ../../playwright.config.cjs",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate --schema=./prisma/schema.prisma",
    "db:push": "prisma db push"
  },
  "prisma": {
    "schema": "./prisma/schema.prisma"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.712.0",
    "@aws-sdk/s3-request-presigner": "^3.712.0",
    "@langchain/core": "0.3.72",
    "@langchain/openai": "0.3.17",
    "@pinecone-database/pinecone": "4.0.0",
    "@prisma/client": "^6.2.0",
    "@rag/ingestion": "workspace:*",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.30.1",
    "ioredis": "^5.10.1",
    "langchain": "0.3.27",
    "langfuse": "^3.29.1",
    "next": "^14.2.21",
    "next-auth": "^4.24.10",
    "openai": "^4.76.0",
    "prom-client": "^15.1.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "uuid": "^11.0.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@playwright/test": "^1.49.1",
    "@rag/config": "workspace:*",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.14",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.21",
    "postcss": "^8.4.49",
    "prisma": "^6.2.0",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
