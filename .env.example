# Redis (BullMQ) — matches docker-compose default port
REDIS_URL=redis://127.0.0.1:6379

# Postgres (Prisma / metadata — Phase 5)
# Uses 5433 on the host to avoid conflicts with a local Postgres on 5432.
DATABASE_URL=postgresql://rag:rag@127.0.0.1:5433/rag_metadata?connect_timeout=15

# NextAuth (JWT sessions)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-a-long-random-string

# Ingestion worker (OpenAI + Pinecone)
OPENAI_API_KEY=
PINECONE_API_KEY=
PINECONE_INDEX_NAME=

# Langfuse (optional traces for /api/query)
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=https://cloud.langfuse.com

# Local file storage (default: ./uploads relative to the process cwd)
RAG_UPLOAD_DIR=

# Optional S3 — set RAG_USE_S3=true and bucket when not using local disk
RAG_USE_S3=false
RAG_S3_BUCKET=
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
