# Redis (BullMQ) — matches docker-compose default port
REDIS_URL=redis://127.0.0.1:6379

# Postgres (Prisma / metadata — Phase 5)
# Uses 5433 on the host to avoid conflicts with a local Postgres on 5432.
DATABASE_URL=postgresql://rag:rag@127.0.0.1:5433/rag_metadata?connect_timeout=15

# NextAuth (JWT sessions)
# Must match the URL you open in the browser (127.0.0.1 vs localhost).
NEXTAUTH_URL=http://127.0.0.1:3000
NEXTAUTH_SECRET=generate-a-long-random-string

# LLM providers: ollama | gemini | openai
RAG_CHAT_PROVIDER=gemini
RAG_EMBEDDING_PROVIDER=gemini

# Gemini (Google AI Studio)
GEMINI_API_KEY=
GOOGLE_API_KEY=
GEMINI_CHAT_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# Optional local Ollama fallback
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_CHAT_MODEL=llama3.1
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Vector DB priority:
# 1) If PINECONE_API_KEY + PINECONE_INDEX_NAME are set → Pinecone (preferred)
# 2) Otherwise → local Qdrant
# Optional force: RAG_VECTOR_PROVIDER=pinecone|qdrant
RAG_VECTOR_PROVIDER=
PINECONE_API_KEY=
PINECONE_INDEX_NAME=

# Local Qdrant fallback
QDRANT_URL=http://127.0.0.1:6333
QDRANT_COLLECTION=rag_chunks
QDRANT_API_KEY=

# Optional OpenAI
OPENAI_API_KEY=

# Langfuse (optional traces for /api/query)
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=https://cloud.langfuse.com

# File storage priority:
# 1) Supabase when SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY + SUPABASE_STORAGE_BUCKET are set
# 2) S3 when RAG_USE_S3=true
# 3) Local disk (RAG_UPLOAD_DIR)
# Optional force: RAG_STORAGE_PROVIDER=supabase|s3|local
RAG_STORAGE_PROVIDER=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=rag-uploads

# Shared upload folder for web + worker (local fallback; prefer absolute path)
# Example: /Users/you/dev/RAG/uploads
RAG_UPLOAD_DIR=

# Optional S3 — set RAG_USE_S3=true and bucket when not using Supabase/local
RAG_USE_S3=false
RAG_S3_BUCKET=
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
