# Redis (BullMQ) — matches docker-compose default port
REDIS_URL=redis://127.0.0.1:6379

# Postgres (Prisma / metadata — Phase 5)
# Uses 5433 on the host to avoid conflicts with a local Postgres on 5432.
DATABASE_URL=postgresql://rag:rag@127.0.0.1:5433/rag_metadata?connect_timeout=15

# NextAuth (JWT sessions)
# Must match the URL you open in the browser (127.0.0.1 vs localhost).
NEXTAUTH_URL=http://127.0.0.1:3000
NEXTAUTH_SECRET=generate-a-long-random-string

# LLM providers: ollama | gemini | openai
RAG_CHAT_PROVIDER=gemini
RAG_EMBEDDING_PROVIDER=gemini
RAG_VECTOR_PROVIDER=qdrant

# Gemini (Google AI Studio) — free-tier friendly alternative to OpenAI
GEMINI_API_KEY=
GOOGLE_API_KEY=
GEMINI_CHAT_MODEL=gemini-2.0-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# Optional local Ollama fallback
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_CHAT_MODEL=llama3.1
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
QDRANT_URL=http://127.0.0.1:6333
QDRANT_COLLECTION=rag_chunks
QDRANT_API_KEY=

# Optional OpenAI / Pinecone
OPENAI_API_KEY=
PINECONE_API_KEY=
PINECONE_INDEX_NAME=

# Langfuse (optional traces for /api/query)
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=https://cloud.langfuse.com

# Shared upload folder for web + worker (prefer an absolute path)
# Example: /Users/you/dev/RAG/uploads
RAG_UPLOAD_DIR=

# Optional S3 — set RAG_USE_S3=true and bucket when not using local disk
RAG_USE_S3=false
RAG_S3_BUCKET=
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
