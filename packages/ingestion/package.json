    "openai": "^4.76.0",
    "pdf-parse": "^1.1.1"
  },
  "devDependencies": {
    "@rag/config": "workspace:*",
    "@types/pdf-parse": "^1.1.4",
    "eslint": "^8.57.1",
    "typescript": "^5.7.2"
  }
